{
  "expo": {
    "name": "MiniGamesWF",
    "slug": "minigameswf",
    "scheme": "minigameswf",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#171311"
    },
    "ios": {
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:minigameswf.app"
      ]
    },
    "android": {
      "package": "app.minigameswf.android",
      "versionCode": 1,
      "icon": "./assets/icon-1024.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#171311"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "minigameswf.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "minigameswf",
              "host": "join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MiniGamesWF to scan room QR codes."
        }
      ],
      "expo-barcode-scanner",
      "expo-web-browser"
    ]
  }
}
